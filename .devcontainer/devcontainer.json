{
    "name": "GEN_AI_Course",
    "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
    "features": {
        "ghcr.io/devcontainers/features/conda:1": {
            "version": "latest"
        }
    },
    "postCreateCommand": "conda env create -f settings/environment.yml && conda init bash && echo 'conda activate genai-course' >> ~/.bashrc",
    "customizations": {
        "vscode": {
            "settings": {
                "python.defaultInterpreterPath": "/opt/conda/envs/genai-course/bin/python",
                "python.testing.pytestArgs": [
                    "tests"
                ],
                "python.testing.unittestEnabled": false,
                "python.testing.pytestEnabled": true,
                "python.testing.pytestPath": "pytest",
                "terminal.integrated.shell.linux": "/bin/bash"
            },
            "extensions": [
                "ms-python.python",
                "ms-python.pylint",
                "ms-python.black-formatter",
                "ms-vscode.vscode-json",
                "redhat.vscode-yaml"
            ]
        }
    },
    "forwardPorts": [],
    "portsAttributes": {},
    "remoteUser": "vscode"
}